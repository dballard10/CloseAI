# Copy to .env and fill in. All values are optional and have sane defaults.

# --- Weave / W&B (sponsor) — the only thing you really need to fill in ---
# Get your 40-char key at https://wandb.ai/authorize (or just run `wandb login`).
WANDB_API_KEY=
WEAVE_PROJECT=closeai

# --- Agent 2: local LLM detector (Ollama) ---
# If OLLAMA_MODEL isn't installed, the agent auto-selects an installed model
# (run `ollama list` to see yours). Set this to pin a specific one.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
ENABLE_LLM_DETECTOR=1

# --- Agent 1: Presidio / spaCy (local, no keys) ---
SPACY_MODEL=en_core_web_lg
PRESIDIO_THRESHOLD=0.35

# --- Closed model = a local Ollama model (no API key, nothing leaves the box) ---
# Auto-falls back to an installed model if this one isn't pulled.
CLOSEAI_MODEL=llama3.2
