# Copy to .env and fill in. All values are optional and have sane defaults.

# --- Weave / W&B (sponsor) ---
WEAVE_PROJECT=closeai
# Get a key at https://wandb.ai/authorize then `wandb login` or export it.
# Never commit a real key.
WANDB_API_KEY=

# --- Agent 2: local LLM detector (Ollama) ---
# If OLLAMA_MODEL isn't installed, the agent auto-selects an installed model
# (run `ollama list` to see yours). Set this to pin a specific one.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
ENABLE_LLM_DETECTOR=1

# --- ClosedAI privacy-gate LLM mode ---
# Trusted local agent prompts run through Ollama when enabled. The system falls
# back to deterministic logic if Ollama is unavailable.
CLOSEDAI_USE_LLM=1
CLOSEDAI_LOCAL_MODEL=llama3.2:3b
CLOSEDAI_LLM_STEPS=pipeline,finalize
CLOSEDAI_UTILITY_THRESHOLD=0.6
CLOSEDAI_UTILITY_RETRIES=1

# External consultant provider. Keep mock for offline demos, or set wandb to use
# W&B Inference after the sanitized prompt passes the privacy gate.
# Leave blank to auto-use W&B when WANDB_API_KEY is set, otherwise mock.
CLOSEDAI_EXTERNAL_PROVIDER=
CLOSEDAI_EXTERNAL_MODEL=meta-llama/Llama-3.1-8B-Instruct

# --- Agent 1: Presidio / spaCy ---
SPACY_MODEL=en_core_web_lg
PRESIDIO_THRESHOLD=0.35

# --- Closed-source model (the untrusted party) ---
# provider: openai | anthropic | wandb | ollama | echo
#   ollama = use a local model as the "closed" model (great for testing, no key)
#   echo   = offline stub, just echoes the masked prompt back
# For provider=ollama, set CLOSEAI_MODEL to an installed model (e.g. llama2:latest);
# if it's not installed it auto-falls back to one that is.
CLOSEAI_PROVIDER=echo
CLOSEAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- W&B Inference (when CLOSEAI_PROVIDER=wandb) ---
# Do NOT name this WANDB_BASE_URL — that var is reserved by wandb/weave for the
# W&B platform and setting it to the inference URL breaks Weave tracing.
WANDB_INFERENCE_BASE_URL=https://api.inference.wandb.ai/v1
